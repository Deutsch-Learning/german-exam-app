# Required on Railway / staging
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
JWT_SECRET=use-a-long-random-string

# Public URL of the Vercel frontend (no trailing slash)
FRONTEND_URL=https://your-app.vercel.app

# Optional: comma-separated extra origins (preview URLs, alternate domains)
# CORS_ORIGINS=https://branch-name.vercel.app

# Optional: allow any https://*.vercel.app origin (useful for preview deploys)
# CORS_ALLOW_VERCEL_PREVIEWS=true

NODE_ENV=production

# Local Postgres without SSL only — omit or set false when using Supabase
# DATABASE_SSL=false
