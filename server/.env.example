# Required in production. Supabase works well because this app uses PostgreSQL.
# If your password includes reserved URL characters such as @ or #, encode them:
# @ -> %40 and # -> %23
DATABASE_URL=postgresql://postgres:YOUR_ENCODED_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
JWT_SECRET=use-a-long-random-string

# Required for Continue with Google. Keep GOOGLE_CLIENT_SECRET server-side only.
# The matching public client ID also belongs in client/gem-app/.env as VITE_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-web-client-secret

# Public website URL (no trailing slash)
APP_BASE_URL=https://xn--n-deutschprfungen-d3b.com
FRONTEND_URL=https://xn--n-deutschprfungen-d3b.com
VERIFY_EMAIL_URL=https://xn--n-deutschprfungen-d3b.com/verify-email
RESET_PASSWORD_URL=https://xn--n-deutschprfungen-d3b.com/reset-password

# Optional: comma-separated extra origins, such as the www domain.
CORS_ORIGINS=https://n-deutschprüfungen.com,https://www.n-deutschprüfungen.com,https://xn--n-deutschprfungen-d3b.com,https://www.xn--n-deutschprfungen-d3b.com

NODE_ENV=production
PORT=3000

# Required for AI-powered Expression Ecrite correction. Keep this server-side only.
GEMINI_API_KEY=your-gemini-api-key
# Optional override. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash
# Optional request guard. Defaults to 25s on Vercel, 60s elsewhere.
# WRITING_CORRECTION_DEADLINE_MS=60000

# Required for production-quality Hoeren audio generation. Keep these server-side only.
# Pick one provider. If TTS_PROVIDER is unset, the server chooses the first configured key.
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=your-elevenlabs-api-key
# Optional. If omitted, the server picks the best German/multilingual voice available on the account.
# ELEVENLABS_DEFAULT_VOICE_ID=your-elevenlabs-voice-id
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# TTS_MAX_ATTEMPTS=3

# Optional alternative TTS providers.
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# OPENAI_TTS_VOICE=nova
# Optional Sprechen AI correction. Keep server-side only. Leave unset until OpenAI credits are available.
# OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# OPENAI_DIARIZE_MODEL=gpt-4o-transcribe-diarize
# OPENAI_EVAL_MODEL=gpt-4.1-mini
# SPEAKING_RECORDING_MAX_BYTES=8388608
# GOOGLE_TTS_API_KEY=your-google-cloud-tts-key
# GOOGLE_TTS_VOICE=de-DE-Neural2-B
# AZURE_SPEECH_KEY=your-azure-speech-key
# AZURE_SPEECH_REGION=westeurope
# AZURE_TTS_VOICE=de-DE-KatjaNeural
# AWS_ACCESS_KEY_ID=your-aws-access-key-id
# AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# AWS_REGION=eu-central-1
# POLLY_TTS_VOICE=Vicki

# Email verification is soft by default: users are prompted but not blocked.
EMAIL_VERIFICATION_ENABLED=true
EMAIL_VERIFICATION_MODE=soft

# Required for real email verification/password reset/welcome delivery.
# Keep RESEND_API_KEY server-side only. Leave unset locally to log emails.
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=no-reply@xn--n-deutschprfungen-d3b.com
EMAIL_FROM_NAME=Deutschprüfungen
SUPPORT_EMAIL=support@xn--n-deutschprfungen-d3b.com
CONTACT_TO=support@xn--n-deutschprfungen-d3b.com

# Optional SMTP fallback. For Resend SMTP use smtp.resend.com, user resend, and API key as password.
# EMAIL_SMTP_HOST=smtp.resend.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=resend
# EMAIL_SMTP_PASS=your-resend-api-key

# Local Postgres without SSL only - omit when using Supabase
# DATABASE_SSL=false
