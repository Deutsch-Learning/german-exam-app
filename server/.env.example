# Required in production. Supabase works well because this app uses PostgreSQL.
# If your password includes reserved URL characters such as @ or #, encode them:
# @ -> %40 and # -> %23
DATABASE_URL=postgresql://postgres:YOUR_ENCODED_PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
JWT_SECRET=use-a-long-random-string

# Public website URL (no trailing slash)
FRONTEND_URL=https://xn--n-deutschprfungen-d3b.com

# Optional: comma-separated extra origins, such as the www domain.
CORS_ORIGINS=https://www.xn--n-deutschprfungen-d3b.com

NODE_ENV=production
PORT=3000

# Required for AI-powered Expression Ecrite correction. Keep this server-side only.
GEMINI_API_KEY=your-gemini-api-key
# Optional override. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash
# Optional request guard. Defaults to 25s on Vercel, 60s elsewhere.
# WRITING_CORRECTION_DEADLINE_MS=60000

# Required for real email verification/password reset delivery.
# Leave unset temporarily: the server logs emails instead of sending them.
EMAIL_SMTP_HOST=smtp.your-provider.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-user
EMAIL_SMTP_PASS=your-smtp-password
# EMAIL_FROM=no-reply@xn--n-deutschprfungen-d3b.com

# Local Postgres without SSL only - omit when using Supabase
# DATABASE_SSL=false
